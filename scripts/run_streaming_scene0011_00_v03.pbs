#!/bin/bash
#PBS -N streaming_scene0011_00_v03
#PBS -q coss_agpu
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb:Qlist=agpu
#PBS -l walltime=01:00:00
#PBS -j oe

PROJECT_ROOT=/home/rintern16/OpenYOLO3D
cd "$PROJECT_ROOT"

DATE=$(date +%F)
EXP=streaming_scene0011_00_v03_filter_npy
N=$(printf '%02d' $(($(ls -d "results/${DATE}_${EXP}_v"* 2>/dev/null | wc -l) + 1)))
RUN_DIR="${PROJECT_ROOT}/results/${DATE}_${EXP}_v${N}"
export RUN_DIR
mkdir -p "$RUN_DIR/outputs"
cp pretrained/config_scannet200.yaml "$RUN_DIR/config.yaml"

LOG="$RUN_DIR/run.log"
exec >"$LOG" 2>&1

echo "=== Run directory: $RUN_DIR ==="
echo "=== Diagnosis: scene0011_00 with filter=True + projection=.npy (Task 1.2c Option A) ==="
echo "=== Date: $(date) ==="

source /home/rintern16/miniconda3/etc/profile.d/conda.sh
conda activate openyolo3d

python -m method_scannet.streaming.run_streaming_scene \
  --scene scene0011_00 \
  --output "$RUN_DIR" \
  --config pretrained/config_scannet200.yaml \
  --mask3d-filter \
  --projection-index npy

EXIT=$?
echo "=== exit code: $EXIT ==="
exit $EXIT
