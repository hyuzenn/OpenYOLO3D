# 1. 파이썬 관련 캐시
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/

# 2. 데이터셋 및 모델 체크포인트 (가장 큰 토큰 도둑)
data/
datasets/
pretrained/checkpoints/
pretrained/**/*.pth
pretrained/**/*.ckpt

# Replica 데이터셋 (evaluate/replica/ 소스코드는 영향 없음)
