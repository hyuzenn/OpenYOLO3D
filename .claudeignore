**/replica/room*/
**/replica/ground_truth/
**/replica/groundtruth/
*.zip
*.tar.gz
*.pth
*.ckpt
*.onnx
*.bin
*.weights
*.pb

# 3. 외부 모델 라이브러리 (직접 수정하지 않으면 무시)
models/Mask3D/third_party/
models/Mask3D/build/
models/Mask3D/mask3d.egg-info/
models/YOLO-World/third_party/
models/YOLO-World/data/
models/YOLO-World/docs/
models/YOLO-World/demo/

# 4. 실험 결과 및 출력물
results/
evaluate/outputs/
outputs/

# 5. 문서 이미지 (텍스트가 아닌 큰 파일)
